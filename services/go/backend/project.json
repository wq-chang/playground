{
  "name": "go-backend",
  "projectType": "application",
  "sourceRoot": "services/go/backend",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go build -v ./...",
        "cwd": "services/go/backend"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "gotestsum --format testname -- -v ./...",
        "cwd": "services/go/backend"
      },
      "dependsOn": ["^build"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "golangci-lint run ./...",
        "cwd": "services/go/backend"
      }
    },
    "docker": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -f services/go/backend/Dockerfile -t go-backend:${GIT_SHA:-latest} -t go-backend:latest .",
        "cwd": "services/go/backend"
      },
      "dependsOn": ["build", "test", "lint"]
    },
    "docker-push": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker push go-backend:${GIT_SHA:-latest} && docker push go-backend:latest"
      },
      "dependsOn": ["docker"]
    }
  },
  "implicitDependencies": ["go-services", "go-library"],
  "tags": ["type:app", "scope:backend", "language:go"]
}
