{
  "name": "go-library",
  "projectType": "library",
  "root": "services/go/library",
  "sourceRoot": "services/go/library",
  "targets": {
    "build-go": {},
    "build": {
      "dependsOn": ["build-go"],
      "executor": "nx:noop"
    },
    "test-go": {},
    "test": {
      "dependsOn": ["test-go"],
      "executor": "nx:noop"
    },
    "format-go": {},
    "format": {
      "dependsOn": ["format-go"],
      "executor": "nx:noop"
    },
    "lint-go": {},
    "lint": {
      "dependsOn": ["lint-go"],
      "executor": "nx:noop"
    },
    "docker": {
      "executor": "nx:noop"
    },
    "docker-push": {
      "executor": "nx:noop"
    }
  },
  "implicitDependencies": ["go-services"],
  "tags": ["type:lib", "scope:backend", "language:go", "shared:true"]
}
