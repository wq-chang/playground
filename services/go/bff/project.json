{
  "name": "go-bff",
  "projectType": "application",
  "sourceRoot": "services/go/bff",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd services/go/bff && go build -v ./...",
        "cwd": "."
      },
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd services/go/bff && gotestsum --format testname -- -v ./...",
        "cwd": "."
      },
      "dependsOn": ["^build"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd services/go/bff && golangci-lint run ./...",
        "cwd": "."
      }
    },
    "docker": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -f .docker/Dockerfile.go --build-arg SERVICE_NAME=bff -t go-bff:${GIT_SHA:-latest} -t go-bff:latest .",
        "cwd": "."
      },
      "dependsOn": ["build", "test", "lint"],
      "outputs": []
    },
    "docker-push": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker push go-bff:${GIT_SHA:-latest} && docker push go-bff:latest",
        "cwd": "."
      },
      "dependsOn": ["docker"]
    }
  },
  "implicitDependencies": ["go-library"],
  "tags": ["type:app", "scope:backend", "language:go"]
}
